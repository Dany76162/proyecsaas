{
  "name": "@workspace/proyecsaas",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 25195 --hostname 0.0.0.0",
    "worker:dev": "npx tsx --conditions=react-server src/server/workers/start.ts",
    "prebuild": "node scripts/check-tour360-invariants.mjs",
    "build": "next build",
    "start": "prisma db execute --file prisma/repair-production-media.sql --schema prisma/schema.prisma || true && prisma migrate resolve --rolled-back 20260521120000_add_property_media_categories || true && prisma migrate resolve --rolled-back 20260521133000_add_panorama_spatial_fields || true && prisma migrate deploy && next start -H 0.0.0.0",
    "typecheck": "prisma generate && tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.js",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1057.0",
    "@aws-sdk/s3-request-presigner": "^3.1057.0",
    "@prisma/client": "^6.5.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@types/pg": "^8.20.0",
    "@uploadthing/react": "^7.3.3",
    "@xyflow/react": "^12.10.2",
    "bullmq": "^5.46.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "earcut": "^3.0.0",
    "framer-motion": "^12.23.24",
    "ioredis": "^5.4.1",
    "konva": "^10.3.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.14.0",
    "maplibre-gl": "^5.24.0",
    "next": "^15.2.0",
    "next-cloudinary": "^6.17.5",
    "openai": "^6.33.0",
    "pg": "^8.20.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-konva": "^19.2.5",
    "react-zoom-pan-pinch": "^4.0.3",
    "server-only": "^0.0.1",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "three": "^0.184.0",
    "uploadthing": "^7.7.4",
    "web-push": "^3.6.7",
    "zod": "^3.24.2",
    "zustand": "^5.0.14"
  },
