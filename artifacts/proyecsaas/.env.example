# -----------------------------------------------------------------------------
# RAICESPILOT - PRODUCTION ENVIRONMENT TEMPLATE
# -----------------------------------------------------------------------------
# Copiá este archivo como .env y completá los valores reales.
# NO subas el archivo .env real con secretos al repositorio.

# --- INFRAESTRUCTURA CORE ---
# URL de la base de datos (Railway provee estas)
DATABASE_URL="postgresql://user:pass@host:port/db?pgbouncer=true"
DIRECT_URL="postgresql://user:pass@host:port/db"

# URL de Redis (Requerido para BullMQ / Workers)
REDIS_URL="redis://default:pass@host:port"

# URL Pública de la Aplicación (Ej: https://mi-app.railway.app)
NEXT_PUBLIC_APP_URL="http://localhost:25195"

# --- AUTENTICACIÓN Y SEGURIDAD ---
# Secreto para firmar cookies de sesión (String aleatorio largo)
AUTH_SESSION_SECRET="generar-un-string-aleatorio-de-64-caracteres"

# Password compartido de emergencia para Superadmins iniciales
AUTH_SHARED_PASSWORD="password-maestro-de-emergencia"

# --- INTELIGENCIA ARTIFICIAL ---
# API Key de OpenAI (Debe tener créditos activos)
OPENAI_API_KEY="sk-..."

# --- WHATSAPP CLOUD API (META) ---
# Secret de la App de Meta (para validar firmas de webhooks)
WHATSAPP_APP_SECRET="tu-app-secret-de-meta"

# Token de verificación configurado en el Dashboard de Meta
WHATSAPP_WEBHOOK_VERIFY_TOKEN="tu-verify-token-personalizado"

# Llave de cifrado para tokens de clientes (String aleatorio de 32 chars)
WHATSAPP_TOKEN_ENCRYPTION_KEY="generar-un-string-aleatorio-de-32-caracteres"

# (Legacy/Opcional) Configuración central de WhatsApp
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ORGANIZATION_ID=""
WHATSAPP_ACCESS_TOKEN=""

# --- MERCADO PAGO ---
# Secret del Webhook de Mercado Pago para validar pagos
MERCADO_PAGO_WEBHOOK_SECRET="tu-webhook-secret-de-mp"

# --- ALMACENAMIENTO (OPCIONAL) ---
UPLOADTHING_SECRET="sk_live_..."
UPLOADTHING_APP_ID="..."

CLOUDINARY_URL="cloudinary://..."
# --- FEATURE FLAGS ---
AGENTOS_ENABLE_PROSPECTING_CENTER=true
AGENTOS_ENABLE_PROSPECTING_EMAIL_SEND=false
AGENTOS_ENABLE_PROSPECTING_CRAWLER=false
AGENTOS_ENABLE_PROSPECTING_AUTOMATION=false
