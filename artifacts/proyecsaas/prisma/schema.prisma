generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  directUrl         = env("DIRECT_URL")
}

enum MembershipRole {
  OWNER
  ADMIN
  AGENT
  ASSISTANT
}

enum LeadStatus {
  NEW
  CONTACTED
  INTERESTED
  VISIT
  CLOSED
}

enum PropertyStatus {
  DRAFT
  AVAILABLE
  RESERVED
  SOLD
  RENTED
}

enum PropertyImageCategory {
  PANORAMA
  REAL
  RENDER
  PROGRESS
}

enum VisitStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELED
}

enum ConversationStatus {
  OPEN
  QUALIFIED
  CLOSED
}

enum FollowUpCategory {
  TECHNICAL
  COMMERCIAL
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageDeliveryStatus {
  RECEIVED
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum NotificationType {
  VISIT_CREATED
  OPERATOR_ACTION_REQUIRED
  FOLLOW_UP_RESOLVED
}

enum BillingStatus {
  PENDING
  PAID
  CANCELLED
  OVERDUE
  ARCHIVED
}

enum InvoiceStatus {
  PENDING
  ISSUED
  EXEMPT
}

enum WhatsAppProvider {
  WHATSAPP_CLOUD
  EVOLUTION_API
}

enum WhatsAppChannelStatus {
  ACTIVE
  INACTIVE
  DISCONNECTED
  ERROR
}

enum WhatsAppChannelVerificationStatus {
  PENDING
  VERIFIED
  FAILED
  REVOKED
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
  SUSPENDED
}

enum ContentCalendarStatus {
  UNSCHEDULED
  SCHEDULED
  USED_MANUALLY
  ARCHIVED
}

enum BillingMode {
  ONLINE
  CASH
  TRANSFER
  COURTESY
  MANUAL
}

model User {
  id                String             @id @default(cuid())
  email             String             @unique
  fullName          String
  jobTitle          String?
  phone             String?
  whatsapp          String?
  zone              String?
  agentNotes        String?
  isActive          Boolean            @default(true)
  isPlatformAdmin   Boolean            @default(false)
  passwordHash      String?
  availabilitySlots AvailabilitySlot[]
  memberships       Membership[]
  ownedLeads        Lead[]             @relation("LeadOwner")
  createdVisits     Visit[]            @relation("VisitCreatedBy")
  createdAgentTasks AgentTask[]        @relation("TaskCreatedBy")
  decidedApprovals  AgentApproval[]    @relation("ApprovalDecidedBy")
  automations      AgentAutomation[]
  inviteTokens      InviteToken[]
  passwordResetTokens PasswordResetToken[]
  termsAcceptedAt   DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model InviteToken {
  id             String       @id @default(cuid())
  token          String       @unique
  userId         String
  organizationId String?
  usedAt         DateTime?
  expiresAt      DateTime
  createdAt      DateTime      @default(now())
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([organizationId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@index([userId])
}

model Organization {
  id                     String             @id @default(cuid())
  name                   String
  slug                   String             @unique
  city                   String?
  planLabel              String?
  marketFocus            String?
  description            String?
  contactEmail           String?
  contactPhone           String?
  contactWhatsapp        String?
  website                String?
  businessHours          String?
  propertySourceUrl      String?
  propertySourceType     String?
  propertySourceStatus   String             @default("IDLE")
  propertySourceSyncedAt DateTime?
  isActive               Boolean            @default(true)
  deletedAt              DateTime?
  maxAiAgents            Int?
  agentQuotaNote         String?
  memberships            Membership[]
  inviteTokens           InviteToken[]
  leads                  Lead[]
  properties             Property[]
  conversations          Conversation[]
  availability           AvailabilitySlot[]
  notifications          Notification[]
  visits                 Visit[]
  automations            AutomationRule[]
  whatsappChannels       WhatsAppChannel[]
  whatsappConnectionRequests WhatsAppChannelConnectionRequest[]
  billingRecords         OrgBillingRecord[]
  aiAgents               AiAgent[]
  subscription           Subscription?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
}

model Membership {
  id             String         @id @default(cuid())
  role           MembershipRole
  userId         String
  organizationId String
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime       @default(now())

  @@unique([userId, organizationId])
  @@index([organizationId, role])
}

model Lead {
  id             String         @id @default(cuid())
  organizationId String
  ownerId        String?
  propertyId     String?
  fullName       String
  email          String?
  phone          String?
  status         LeadStatus     @default(NEW)
  source         String?
  notes          String?
  interestLabel  String?
  budgetLabel    String?
  lastContactAt  DateTime?
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  owner          User?          @relation("LeadOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  property       Property?      @relation("LeadPropertyInterest", fields: [propertyId, organizationId], references: [id, organizationId], onDelete: Restrict)
  conversations  Conversation[]
  visits         Visit[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([id, organizationId])
  @@index([organizationId, status])
  @@index([organizationId, ownerId])
  @@index([organizationId, propertyId])
}

model Property {
  id                String             @id @default(cuid())
  organizationId    String
  title             String
  description       String?
  operationType     String?
  address           String?
  city              String?
  neighborhood      String?
  propertyType      String?
  latitude          Decimal?           @db.Decimal(10, 7)
  longitude         Decimal?           @db.Decimal(10, 7)
  priceCents        Int?
  currency          String?            @default("USD")
  expensesCents     Int?
  status            PropertyStatus     @default(DRAFT)
  publicVisible     Boolean            @default(false)
  rooms             Int?
  bedrooms          Int?
  bathrooms         Int?
  surfaceM2         Int?
  parkingSpots      Int?
  amenities         String?
  externalLink      String?
  videoUrl          String?
  floorPlanUrl      String?
  externalSourceUrl String?
  externalId        String?
  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversations     Conversation[]     @relation("ConversationPropertyContext")
  interestedLeads   Lead[]             @relation("LeadPropertyInterest")
  availability      AvailabilitySlot[]
  visits            Visit[]            @relation("PropertyVisits")
  images            PropertyImage[]
  panoramas         PropertyPanorama[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@unique([id, organizationId])
  @@index([organizationId, status])
  @@index([organizationId, publicVisible])
}

model PropertyImage {
  id             String   @id @default(cuid())
  propertyId     String
  organizationId String
  url            String
  altText        String?
  category       PropertyImageCategory @default(REAL)
  sortOrder      Int      @default(0)
  isPrimary      Boolean  @default(false)
  property       Property @relation(fields: [propertyId, organizationId], references: [id, organizationId], onDelete: Cascade)
  createdAt      DateTime @default(now())

  @@index([propertyId])
  @@index([organizationId, propertyId])
}

model PropertyPanorama {
  id             String   @id @default(cuid())
  propertyId     String
  organizationId String
  url            String
  label          String?
  direction      String?
  roomName       String?
  floor          Int      @default(0)
  positionX      Float    @default(0)
  positionY      Float    @default(0)
  positionZ      Float    @default(0)
  connections    String   @default("[]")
  sortOrder      Int      @default(0)
  initialYaw     Float    @default(0)
  initialPitch   Float    @default(0)
  initialHfov    Float    @default(100)
  hotspotPitch   Float?
  hotspotYaw     Float?
  property       Property @relation(fields: [propertyId, organizationId], references: [id, organizationId], onDelete: Cascade)
  createdAt      DateTime @default(now())

  @@index([propertyId])
  @@index([organizationId, propertyId])
}

model Conversation {
  id                  String             @id @default(cuid())
  organizationId      String
  leadId              String?
  propertyId          String?
  channel             String
  status              ConversationStatus @default(OPEN)
  followUpActive      Boolean            @default(false)
  followUpCategory    FollowUpCategory?
  followUpReason      String?
  followUpActiveAt    DateTime?
  followUpResolvedAt  DateTime?
  nextBestAction      String?
  nextBestActionAt    DateTime?
  participantName     String?
  participantPhone    String?
  propertyContextNote String?
  subject             String?
  lastMessageAt       DateTime?
  isHumanControlled   Boolean            @default(false)
  organization        Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lead                Lead?              @relation(fields: [leadId, organizationId], references: [id, organizationId], onDelete: Restrict)
  property            Property?          @relation("ConversationPropertyContext", fields: [propertyId, organizationId], references: [id, organizationId], onDelete: Restrict)
  messages            Message[]
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@unique([id, organizationId])
  @@index([organizationId, channel])
  @@index([organizationId, leadId])
  @@index([organizationId, propertyId])
  @@index([organizationId, status])
}

model Message {
  id                  String                @id @default(cuid())
  organizationId      String
  conversationId      String
  externalId          String?               @unique
  direction           MessageDirection
  deliveryStatus      MessageDeliveryStatus @default(RECEIVED)
  body                String
  senderName          String?
  senderPhone         String?
  providerMessageId   String?
  deliveryError       String?
  deliveryAttemptedAt DateTime?
  deliveredAt         DateTime?
  sentAt              DateTime              @default(now())
  conversation        Conversation          @relation(fields: [conversationId, organizationId], references: [id, organizationId], onDelete: Cascade)
  createdAt           DateTime              @default(now())

  @@index([organizationId, conversationId, sentAt])
  @@index([organizationId, direction, deliveryStatus])
}

model Visit {
  id             String       @id @default(cuid())
  organizationId String
  propertyId     String
  leadId         String?
  createdById    String
  status         VisitStatus  @default(PENDING)
  scheduledAt    DateTime
  notes          String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property       Property     @relation("PropertyVisits", fields: [propertyId, organizationId], references: [id, organizationId], onDelete: Cascade)
  lead           Lead?        @relation(fields: [leadId, organizationId], references: [id, organizationId], onDelete: Restrict)
  createdBy      User         @relation("VisitCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId, status])
  @@index([organizationId, scheduledAt])
  @@index([organizationId, propertyId])
  @@index([organizationId, leadId])
}

model AvailabilitySlot {
  id             String       @id @default(cuid())
  organizationId String
  propertyId     String?
  userId         String?
  label          String
  weekday        Int
  startMinute    Int
  endMinute      Int
  timezone       String       @default("America/Buenos_Aires")
  isActive       Boolean      @default(true)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property       Property?    @relation(fields: [propertyId, organizationId], references: [id, organizationId], onDelete: Restrict)
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId, weekday, isActive])
  @@index([organizationId, propertyId])
  @@index([organizationId, userId])
}

model Notification {
  id             String           @id @default(cuid())
  organizationId String
  type           NotificationType
  title          String
  body           String
  metadata       Json?
  link           String?
  entityType     String?
  entityId       String?
  readAt         DateTime?
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime         @default(now())

  @@index([organizationId, createdAt])
  @@index([organizationId, type])
}

model AutomationRule {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  trigger        String
  isActive       Boolean      @default(true)
  config         Json?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId, isActive])
}

model WorkerHeartbeat {
  id         String   @id @default("singleton")
  lastSeenAt DateTime
  updatedAt  DateTime @updatedAt
}

model WhatsAppChannel {
  id                           String                            @id @default(cuid())
  organizationId               String
  name                         String?
  provider                     WhatsAppProvider                  @default(WHATSAPP_CLOUD)
  status                       WhatsAppChannelStatus             @default(INACTIVE)
  verificationStatus           WhatsAppChannelVerificationStatus @default(PENDING)
  phoneNumberId                String                            @unique
  instanceName                 String?                           @unique
  instanceKey                  String?
  wabaId                       String?
  businessAccountId            String?
  businessId                   String?
  displayPhoneNumber           String?
  verifiedDisplayName          String?
  accessTokenEncrypted         String?
  tokenLastValidatedAt         DateTime?
  tokenExpiresAt               DateTime?
  webhookSubscribed            Boolean                           @default(false)
  webhookSubscriptionCheckedAt DateTime?
  lastInboundAt                DateTime?
  lastDeliveryAt               DateTime?
  lastErrorAt                  DateTime?
  lastErrorCode                String?
  lastErrorMessage             String?
  isPrimary                    Boolean                           @default(false)
  isActive                     Boolean                           @default(true)
  providerMetadata             Json?
  organization                 Organization                      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt                    DateTime                          @default(now())
  updatedAt                    DateTime                          @updatedAt

  @@index([organizationId, provider, status])
  @@index([organizationId, isPrimary])
}

model OrgBillingRecord {
  id             String        @id @default(cuid())
  organizationId String
  description    String
  amountCents    Int
  currency       String        @default("ARS")
  status         BillingStatus @default(PENDING)
  mpPreferenceId String?
  mpPaymentUrl   String?
  mpPaymentId    String?
  // Loose reference to Plan.id — identifies which plan this payment activates.
  // No FK constraint intentional: consistent with activatedByRecordId on Subscription.
  planId         String?
  invoiceStatus  InvoiceStatus @default(PENDING)
  invoiceNumber  String?
  notes          String?

  // Commercial Pro fields
  dueDate             DateTime?
  paidAt              DateTime?
  archivedAt          DateTime?
  paymentMethod       String?
  receiptNumber       String?
  internalNotes       String?       @db.Text
  reminderEnabled     Boolean       @default(true)
  reminderPausedAt    DateTime?
  reminderPauseReason String?

  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@index([dueDate, status])
}

// ─── Commercial catalog ───────────────────────────────────────────────────────

model Plan {
  id          String  @id // human-readable slug: "piloto" | "starter" | "growth"
  name        String
  description String?
  sortOrder   Int
  isActive    Boolean @default(true)

  // Quantitative limits — null means unlimited
  maxUsers            Int?
  maxProperties       Int?
  maxAiAgents         Int?
  maxWhatsAppChannels Int?

  // Feature flags — false means blocked for tenants on this plan
  canUseAiAgents                 Boolean @default(false)
  canUseAutomations              Boolean @default(false)
  canUsePropertySync             Boolean @default(false)
  canExportData                  Boolean @default(false)
  canUseMultipleWhatsAppChannels Boolean @default(false)

  subscriptions Subscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subscription {
  id             String @id @default(cuid())
  organizationId String @unique // enforces one active subscription per org at schema level
  planId         String

  status             SubscriptionStatus @default(TRIALING)
  billingMode        BillingMode?
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean            @default(false)
  internalBillingNotes String?          @db.Text

  // Nullable traceability link — stores OrgBillingRecord.id that activated this subscription.
  // Stored as plain String (no FK constraint) to avoid touching OrgBillingRecord in this phase.
  activatedByRecordId String?

  // SaaS-to-Own and AI controls for Stage 1.5
  planCode                   String?            // e.g. "FOUNDER", "BASE", "PRO", "ENTERPRISE", "CUSTOM"
  paidCycles                 Int                @default(0)
  aiStatus                   String             @default("ACTIVE") // ACTIVE, PAUSED, DISABLED
  aiMonthlyConversationLimit Int                @default(300)
  aiMonthlyConversationsUsed Int                @default(0)
  lifetimeGrantedAt          DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan         Plan         @relation(fields: [planId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([currentPeriodEnd, status])
}

enum AiAgentTone {
  FORMAL
  FRIENDLY
  NEUTRAL
}

model AiAgent {
  id             String       @id @default(cuid())
  organizationId String       @unique // restored @unique for upsert
  whatsappChannelId String?
  name           String       @default("Asistente IA")
  status         String       @default("ACTIVE")
  tone           AiAgentTone  @default(FRIENDLY)
  persona        String?      @db.Text
  language       String       @default("Spanish")
  escalateOnKeywords String[] @default([])
  humanHandoffMessage String? @db.Text
  escalateAfterMessages Int    @default(5)
  
  // Search filters / focus
  zoneFilters    String[]     @default([])
  propertyTypes  String[]     @default([])
  minBudget      Int?
  maxBudget      Int?

  isActive       Boolean      @default(true)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// ─── RaicesPilot AgentOS MVP 1 ───────────────────────────────────────────────

enum AgentScope {
  PLATFORM    // Agentes globales de RaicesPilot
  ORGANIZATION // Agentes por inmobiliaria (futuro)
}

enum AgentType {
  ORCHESTRATOR // Director Operativo IA
  MARKETING    // Agente de Marketing
}

enum TaskStatus {
  PENDING      // Creada, esperando asignación
  ASSIGNED     // Asignada a agente
  IN_PROGRESS  // Ejecutándose
  COMPLETED    // Terminada exitosamente
  FAILED       // Falló
  APPROVAL_PENDING // Esperando aprobación humana
}

enum RunStatus {
  RUNNING      // En ejecución
  COMPLETED    // Terminada OK
  FAILED       // Error
}

enum ApprovalStatus {
  PENDING      // Esperando decisión
  APPROVED     // Aprobado por humano
  REJECTED     // Rechazado por humano
}

enum GoalStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  PAUSED
  FAILED
}

enum GoalType {
  MARKETING
  OPERATIONS
  ONBOARDING
  COMMERCIAL
  AUDIT
}

enum ContentPlatform {
  FACEBOOK
  INSTAGRAM
  LINKEDIN
  WHATSAPP_BUSINESS
}

enum DraftStatus {
  DRAFT        // Borrador generado
  APPROVED     // Aprobado por humano
  REJECTED     // Rechazado por humano
}

enum AgentPriority {
  LOW
  MEDIUM
  HIGH
}

enum AgentLogLevel {
  INFO
  WARN
  ERROR
}

enum MetaIntegrationStatus {
  DISCONNECTED
  CONNECTED
  EXPIRED
  ERROR
}

enum MetaPlatformType {
  FACEBOOK
  INSTAGRAM
  WHATSAPP_BUSINESS
}

enum PublicationStatus {
  DRAFT
  READY
  PUBLISHING
  PUBLISHED
  FAILED
}

model Agent {
  id            String      @id @default(cuid())
  scope         AgentScope  // PLATFORM para MVP
  organizationId String?    // Nullable para agentes PLATFORM
  name          String      // "Director Operativo IA", "Agente de Marketing"
  type          AgentType
  isActive      Boolean     @default(true)
  config        Json        // Config simple (ej: {"tone": "professional"})
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  
  // Relaciones
  tasks         AgentTask[]
  runs          AgentRun[]
  automations   AgentAutomation[]
  governance    AgentGovernancePolicy?
  requestedApprovals AgentApproval[] @relation("ApprovalRequestedBy")
  @@index([scope, organizationId, type])
}

model AgentTask {
  id            String       @id @default(cuid())
  scope         AgentScope   // PLATFORM para MVP
  organizationId String?     // Nullable
  agentId       String?      // Nullable hasta asignación
  title         String
  description   String?
  status        TaskStatus   @default(PENDING)
  priority      AgentPriority @default(MEDIUM)
  goalId        String?      // Asociado a un objetivo operativo
  automationId  String?      // Creada por una automatización
  createdById   String       // User (Superadmin)
  metadata      Json?        // Datos específicos (ej: {"contentType": "post"})
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  
  // Relaciones
  agent         Agent?       @relation(fields: [agentId], references: [id])
  goal          AgentGoal?   @relation(fields: [goalId], references: [id])
  automation    AgentAutomation? @relation(fields: [automationId], references: [id])
  createdBy     User         @relation("TaskCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  runs          AgentRun[]
  approvals     AgentApproval[]
  drafts        ContentDraft[]
  
  @@index([scope, organizationId, status])
}

model AgentRun {
  id            String    @id @default(cuid())
  scope         AgentScope
  organizationId String?
  taskId        String
  agentId       String
  status        RunStatus @default(RUNNING)
  input         Json      // Input de la ejecución
  output        Json?     // Resultado
  error         String?
  startedAt     DateTime  @default(now())
  completedAt   DateTime?
  
  // Relaciones
  task          AgentTask @relation(fields: [taskId], references: [id])
  agent         Agent     @relation(fields: [agentId], references: [id])
  logs          AgentLog[]
  approvals     AgentApproval[]
  
  @@index([scope, organizationId, status])
}

model AgentApproval {
  id                String         @id @default(cuid())
  scope             AgentScope
  organizationId    String?
  taskId            String
  runId             String?
  requestedByAgentId String?       // Agente que solicita aprobación
  decidedByUserId   String?        // Superadmin que decide
  status            ApprovalStatus @default(PENDING)
  comments          String?
  requestedAt       DateTime       @default(now())
  decidedAt         DateTime?
  
  // Relaciones
  task              AgentTask      @relation(fields: [taskId], references: [id])
  run               AgentRun?      @relation(fields: [runId], references: [id])
  requestedByAgent  Agent?         @relation("ApprovalRequestedBy", fields: [requestedByAgentId], references: [id], onDelete: SetNull)
  decidedByUser     User?          @relation("ApprovalDecidedBy", fields: [decidedByUserId], references: [id], onDelete: SetNull)
}

model AgentLog {
  id            String        @id @default(cuid())
  scope         AgentScope
  organizationId String?
  runId         String?
  level         AgentLogLevel
  message       String
  metadata      Json?
  timestamp     DateTime      @default(now())
  
  // Relaciones
  run           AgentRun?     @relation(fields: [runId], references: [id])
  
  @@index([scope, organizationId, timestamp])
}

model AgentGoal {
  id             String      @id @default(cuid())
  title          String
  description    String?
  status         GoalStatus  @default(PENDING)
  type           GoalType
  priority       AgentPriority @default(MEDIUM)
  progress       Int         @default(0)
  targetDate     DateTime?
  tasks          AgentTask[]
  automations    AgentAutomation[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

enum AutomationType {
  CONTENT
  REPORT
  GOAL_REVIEW
  AUDIT
  CUSTOM
}

enum AutomationFrequency {
  DAILY
  WEEKLY
  MONTHLY
  MANUAL
}

enum AutomationStatus {
  ACTIVE
  PAUSED
  FAILED
}

model AgentAutomation {
  id             String              @id @default(cuid())
  title          String
  description    String?
  scope          AgentScope          @default(PLATFORM)
  organizationId String?
  agentId        String?
  agent          Agent?              @relation(fields: [agentId], references: [id])
  goalId         String?
  goal           AgentGoal?          @relation(fields: [goalId], references: [id])
  type           AutomationType      @default(CONTENT)
  frequency      AutomationFrequency @default(MANUAL)
  dayOfWeek      Int?                // 0-6 for weekly
  timeOfDay      String?             // HH:mm
  timezone       String              @default("UTC")
  isActive       Boolean             @default(true)
  status         AutomationStatus    @default(ACTIVE)
  lastRunAt      DateTime?
  nextRunAt      DateTime?
  createdById    String
  createdBy      User                @relation(fields: [createdById], references: [id])
  metadata       Json?
  tasks          AgentTask[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([organizationId])
  @@index([agentId])
  @@index([goalId])
  @@index([createdById])
}

model ContentDraft {
  id            String          @id @default(cuid())
  scope         AgentScope
  organizationId String?
  taskId        String
  platform      ContentPlatform
  type          String          // "post", "reel", "story", "message"
  title         String?
  content       String          // Texto generado
  hashtags      String[]        // Array de hashtags
  imagePrompt   String?         // Prompt para imagen (futuro)
  status        DraftStatus     @default(DRAFT)
  
  // Calendario y Programación Interna
  scheduledFor     DateTime?
  calendarStatus   ContentCalendarStatus @default(UNSCHEDULED)
  plannedPlatform  ContentPlatform?
  notes            String?

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  
  // Relaciones
  task          AgentTask       @relation(fields: [taskId], references: [id])
  publications  ContentPublication[]
  
  @@index([scope, organizationId, status])
}

model MetaIntegration {
  id              String   @id @default(cuid())
  scope           AgentScope @default(PLATFORM)
  organizationId  String?
  accessToken     String   // Cifrado
  refreshToken    String?  // Cifrado
  expiresAt       DateTime?
  scopes          String[]
  status          MetaIntegrationStatus @default(DISCONNECTED)
  lastSyncAt      DateTime?
  errorMessage    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  pages           MetaPage[]
  @@index([scope, organizationId])
}

model MetaPage {
  id              String   @id @default(cuid())
  integrationId   String
  pageId          String
  name            String
  platform        MetaPlatformType
  accessToken     String?  // Token específico de página (si aplica, cifrado)
  status          String?
  metadata        Json?
  lastSyncAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  integration     MetaIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  @@index([integrationId])
  @@index([pageId])
}

model ContentPublication {
  id              String   @id @default(cuid())
  draftId         String
  pageId          String
  platform        MetaPlatformType
  status          PublicationStatus @default(DRAFT)
  externalPostId  String?
  errorMessage    String?
  publishedById   String?  // ID del Superadmin que publicó
  publishedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  draft           ContentDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)
  @@index([draftId])
  @@index([status])
}

model AuditLog {
  id          String   @id @default(cuid())
  event       String
  actorId     String?
  actorEmail  String?
  entityType  String?
  entityId    String?
  entityName  String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([event])
  @@index([entityId])
  @@index([createdAt])
}

model GlobalSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([key])
}

enum AgentAutonomyLevel {
  SUGGEST_ONLY
  CREATE_DRAFTS
  REQUIRE_APPROVAL
  MANUAL_ONLY
}

model AgentGovernancePolicy {
  id                        String   @id @default(cuid())
  agentId                   String   @unique
  scope                     AgentScope @default(PLATFORM)
  organizationId            String?
  maxTasksPerDay            Int?     @default(10)
  maxRunsPerDay             Int?     @default(50)
  maxAutomationRunsPerDay   Int?     @default(20)
  maxEstimatedCostPerMonth  Decimal? @default(50.00)
  autonomyLevel             AgentAutonomyLevel @default(REQUIRE_APPROVAL)
  isPaused                  Boolean  @default(false)
  pauseReason               String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  agent                     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  @@index([scope, organizationId])
}

// ─── Prospecting Center ───────────────────────────────────────────────────

enum ProspectCompanyType {
  REAL_ESTATE_AGENCY
  CONSTRUCTION_COMPANY
  DEVELOPER
  BROKER_AGENT
  PROPERTY_MANAGER
  LAND_DEVELOPER
  REAL_ESTATE_GROUP
  ARCHITECTURE_STUDIO
  REAL_ESTATE_INVESTOR
  OTHER_REAL_ESTATE
}

enum ProspectStatus {
  NEW
  NEEDS_REVIEW
  APPROVED
  DISCARDED
  DUPLICATE
  CONTACT_READY
  CONTACTED
  REPLIED
  DEMO_REQUESTED
  CUSTOMER
  DO_NOT_CONTACT
  CONVERTED
}

enum ProspectActivityType {
  created
  imported
  approved
  discarded
  marked_duplicate
  marked_do_not_contact
  converted_to_org
  email_draft_generated
  contact_marked_sent
  reply_logged
  demo_requested
  note_added
  manual_rating_updated
  priority_updated
  manual_status_updated
  review_completed
}

enum ManualRating {
  A
  B
  C
  D
}

enum ProspectPriority {
  HIGH
  MEDIUM
  LOW
}

enum ManualProspectStatus {
  APTO_CONTACTO
  REVISAR
  DESCARTAR
  NO_CONTACTAR
  CONTACTAR_MAS_ADELANTE
}

enum ProspectMessageChannel {
  EMAIL
  WHATSAPP
  LINKEDIN
  OTHER
}

enum ProspectDraftStatus {
  DRAFT
  APPROVED
  REJECTED
  SENT_MANUALLY
}

model CommercialProspect {
  id               String              @id @default(cuid())
  companyName      String
  companyType      ProspectCompanyType @default(OTHER_REAL_ESTATE)
  status           ProspectStatus      @default(NEW)
  
  country          String?
  region           String?
  city             String?
  website          String?
  email            String?
  phone            String?
  whatsapp         String?
  
  instagramUrl     String?
  facebookUrl      String?
  linkedinUrl      String?
  
  sourceUrl        String?
  sourceName       String?
  
  confidenceScore  Int?                @default(0)
  qualityScore     Int?                @default(0)
  fitScore         Int?                @default(0)
  riskScore        Int?                @default(0)
  aiScoringNotes   String?             @db.Text
  
  // Manual qualification by Superadmin
  manualRating     ManualRating?
  priority         ProspectPriority?   @default(MEDIUM)
  manualStatus     ManualProspectStatus?
  manualNotes      String?             @db.Text
  reviewedByUserId String?
  reviewedAt       DateTime?
  contactLaterDate DateTime?
  
  notes            String?             @db.Text
  agentNotes       String?             @db.Text
  internalTags     String[]            @default([])
  
  isDoNotContact   Boolean             @default(false)
  doNotContactReason String?
  
  duplicateOfId    String?
  
  approvedAt       DateTime?
  approvedByUserId String?
  
  discardedAt      DateTime?
  discardedReason  String?
  
  contactedAt      DateTime?
  lastContactedAt  DateTime?
  repliedAt        DateTime?
  demoRequestedAt  DateTime?
  
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  activities       CommercialProspectActivity[]
  messageDrafts    ProspectingMessageDraft[]
  campaigns        ProspectingCampaignRecipient[]

  @@index([status])
  @@index([companyType])
  @@index([email])
  @@index([website])
}

model CommercialProspectActivity {
  id               String               @id @default(cuid())
  prospectId       String
  type             ProspectActivityType
  message          String
  metadata         Json?
  createdByUserId  String?
  createdAt        DateTime             @default(now())

  prospect         CommercialProspect   @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  @@index([prospectId])
}

model ProspectingMessageDraft {
  id               String                 @id @default(cuid())
  prospectId       String
  channel          ProspectMessageChannel @default(EMAIL)
  subject          String?
  body             String                 @db.Text
  status           ProspectDraftStatus    @default(DRAFT)
  generatedByAgent Boolean                @default(false)
  
  approvedAt       DateTime?
  approvedByUserId String?
  
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  prospect         CommercialProspect     @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  @@index([prospectId])
  @@index([status])
}
enum ConnectionRequestStatus {
  PENDING
  IN_REVIEW
  CONNECTED
  REJECTED
  CANCELED
}

model WhatsAppChannelConnectionRequest {
  id                  String                  @id @default(cuid())
  organizationId      String
  requestedPhoneNumber String
  businessName        String
  contactName         String
  contactEmail        String
  notes               String?                 @db.Text
  status              ConnectionRequestStatus @default(PENDING)
  internalNotes       String?                 @db.Text
  reviewedByUserId    String?
  reviewedAt          DateTime?
  
  organization        Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  @@index([organizationId, status])
}

enum CampaignStatus {
  DRAFT
  READY
  SENDING
  SENT
  PAUSED
  FAILED
  CANCELED
}

enum CampaignRecipientStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
  BOUNCED
  UNSUBSCRIBED
}

enum SuppressionReason {
  UNSUBSCRIBED
  DO_NOT_CONTACT
  BOUNCED
  MANUAL_BLOCK
  CUSTOMER
}

model ProspectingCampaign {
  id               String               @id @default(cuid())
  name             String
  subject          String?
  body             String?              @db.Text
  status           CampaignStatus       @default(DRAFT)
  segmentRules     Json?
  totalRecipients  Int                  @default(0)
  sentCount        Int                  @default(0)
  failedCount      Int                  @default(0)
  skippedCount     Int                  @default(0)
  openCount        Int                  @default(0)
  clickCount       Int                  @default(0)
  
  createdByUserId  String?
  approvedByUserId String?
  approvedAt       DateTime?
  sentAt           DateTime?
  
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  recipients       ProspectingCampaignRecipient[]
}

model ProspectingCampaignRecipient {
  id                  String                  @id @default(cuid())
  campaignId          String
  prospectId          String
  email               String
  status              CampaignRecipientStatus @default(PENDING)
  skipReason          String?
  providerMessageId   String?                 @unique
  sentAt              DateTime?
  failedAt            DateTime?
  openedAt            DateTime?
  clickedAt           DateTime?
  errorMessage        String?                 @db.Text
  
  createdAt           DateTime                @default(now())
  
  campaign            ProspectingCampaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  prospect            CommercialProspect      @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([prospectId])
  @@index([status])
  @@index([providerMessageId])
}

model ProspectingSuppression {
  id        String            @id @default(cuid())
  email     String            @unique
  reason    SuppressionReason
  source    String?
  createdAt DateTime          @default(now())
}
