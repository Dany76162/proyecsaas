  Development    Development     @relation(fields: [developmentId], references: [id], onDelete: Cascade)
  DevelopmentLot DevelopmentLot? @relation(fields: [unidadId], references: [id])

  @@index([developmentId])
}

model DevelopmentReservation {
  id             String                       @id @default(cuid())
  lotId          String
  organizationId String
  leadId         String?
  agentId        String?
  status         DevelopmentReservationStatus @default(PENDING_APPROVAL)
  depositCents   Int?
  notes          String?
  expiresAt      DateTime?
  approvedById   String?
  approvedAt     DateTime?
  cancelledById  String?
  cancelledAt    DateTime?
  cancelReason   String?
  createdAt      DateTime                     @default(now())
  updatedAt      DateTime                     @updatedAt

  // ── Mercado Pago payment tracking (Fase 2) ──────────────────────────────────
  // mpPaymentId: used for strong idempotency — stored when MP webhook confirms payment.
  mpPaymentId    String?
  // mpPreferenceId: stored at preference creation time (reserve/route.ts).
  mpPreferenceId String?
  // mpCurrency: currency in which MP charged (always "ARS" for now).
  mpCurrency     String?
  // grossAmountCents: actual amount charged by MP (in centavos).
  grossAmountCents Int?
  // commissionCents: Raíces Pilot fee. Zero until commercial policy is configured per development.
  commissionCents  Int?
  // netAmountCents: amount to settle to the developer (gross - commission).
  netAmountCents   Int?

  // ── Liquidation tracking (Fase 2) ───────────────────────────────────────────
  // settlementStatus tracks whether Raíces Pilot has transferred funds to the developer.
  settlementStatus    ReservationSettlementStatus? @default(PENDING)
  settledAt           DateTime?
  // settlementReference: wire transfer reference, CBU/CVU, or receipt number.
  settlementReference String?
  settlementNotes     String?
  // settledById: Superadmin user ID who registered the settlement.
  // Stored as a plain field (no relation) to avoid conflict with the unnamed
  // User relation on agentId. Full relation will be added in Fase 3.
  settledById         String?

  // ── Gestión de Venta — datos del comprador (Fase F-1) ───────────────────────
  // buyerDni: DNI, CUIT or other document number of the buyer.
  buyerDni          String?
  // buyerWhatsapp: buyer's WhatsApp/phone — normalized format (+54911...).
  buyerWhatsapp     String?

  // ── Operación comercial ──────────────────────────────────────────────────────
  // paymentMethod: EFECTIVO | TRANSFERENCIA | MP | OTRO — stored as free text
  // to avoid premature enum. Will become enum in Fase F-2 if needed.
  paymentMethod     String?
  // paymentReference: wire transfer number, receipt ID, or manual reference.
  paymentReference  String?
  // totalPriceCents: total agreed price of the operation (may differ from lot.priceCents).
  totalPriceCents   Int?
  // downPaymentCents: actual commercial down payment. Distinct from depositCents
  // which tracks the Mercado Pago online deposit flow.
  downPaymentCents  Int?

  // ── Plan de cuotas ───────────────────────────────────────────────────────────
  // installmentCount: number of monthly installments chosen.
  installmentCount       Int?
  // installmentAmountCents: base installment amount in cents (floor division).
  installmentAmountCents Int?
  // firstDueDate: due date of installment #1; subsequent dates add months.
  firstDueDate           DateTime?

  User           User?                        @relation(fields: [agentId], references: [id])
  Lead           Lead?                        @relation(fields: [leadId, organizationId], references: [id, organizationId])
  DevelopmentLot DevelopmentLot               @relation(fields: [lotId], references: [id], onDelete: Cascade)
  Installments   DevelopmentReservationInstallment[]

  @@index([leadId])
  @@index([lotId])
  @@index([organizationId, status])
  @@index([mpPaymentId])
  @@index([mpPreferenceId])
  @@index([settlementStatus])
  @@index([organizationId, settlementStatus])
}

enum DevelopmentLotStatus {
  AVAILABLE
  RESERVED_PENDING
  RESERVED
  SOLD
  BLOCKED
}

enum DevelopmentReservationStatus {
  PENDING_APPROVAL
  ACTIVE
  CANCELLED
  SOLD
}

enum DevelopmentStatus {
  DRAFT
  ACTIVE
  SOLD_OUT
  PAUSED
  CANCELLED
}

// Tracks whether Raíces Pilot has transferred (settled) the reservation funds
// to the developer. Set to PENDING when MP payment is confirmed.
// Updated manually by Superadmin in Fase 3 liquidation panel.
enum VisualGeometryKind {
  POLYGON
  POLYLINE
  RECT
  CIRCLE
  POINT
  TEXT
}

enum VisualCoordinateSpace {
  PLAN_VIEWBOX
  PLAN_NORMALIZED
}

enum VisualVisibility {
  ADMIN_ONLY
  PUBLIC
  BOTH
}

// ── F-1: Gestión de Venta — cronograma de cuotas ────────────────────────────
// Each row represents one monthly installment for a DevelopmentReservation.
// Installments are generated and stored as real rows so that individual
// payments, receipts and overdue states can be tracked independently.
model DevelopmentReservationInstallment {
  id                 String                       @id @default(cuid())
  reservationId      String
  organizationId     String
  installmentNumber  Int
  dueDate            DateTime
  amountCents        Int
  currency           String                       @default("USD")
  status             DevelopmentInstallmentStatus @default(PENDING)
  paidAt             DateTime?
  paymentMethod      String?
  paymentReference   String?
  receiptUrl         String?
  notes              String?
  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @updatedAt

  Reservation DevelopmentReservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@index([reservationId])
  @@index([organizationId, status])
}

enum DevelopmentInstallmentStatus {
  PENDING   // Not yet due or awaiting payment
  PAID      // Payment confirmed
  OVERDUE   // Past due date without payment
  CANCELLED // Installment voided (e.g. plan was renegotiated)
}

enum ReservationSettlementStatus {
  PENDING    // Payment received by Raíces Pilot — settlement to developer pending
  IN_REVIEW  // Under internal review before transfer
  SETTLED    // Funds transferred to developer
  HELD       // Transfer on hold (dispute, refund, or compliance check)
  REFUNDED   // Refunded to the buyer
}
