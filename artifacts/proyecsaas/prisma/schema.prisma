  COMPANY        // Empresa
  ADMINISTRATOR  // Administrador
}

enum FinancialRole {
  OWNER        // Responsable principal — control total
  ADMIN        // Puede aprobar/anular (fase futura)
  CONTADOR     // Solo lectura + exportar (fase futura)
  AUDITOR      // Solo auditoría (fase futura)
  CARGADOR     // Solo cargar gastos (fase futura)
  SOLO_LECTURA // Solo ver balance (fase futura)
