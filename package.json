{
  "name": "proyecsaas",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:web": "next dev",
    "worker:dev": "tsx --conditions=react-server src/server/workers/start.ts",
    "build": "next build",
    "build:web": "next build",
    "start": "next start -H 0.0.0.0 -p ${PORT:-3000}",
    "start:web": "next start -H 0.0.0.0 -p ${PORT:-3000}",
    "prestart:web": "npm run validate:runtime:web",
    "worker:start": "tsx --conditions=react-server src/server/workers/start.ts",
    "preworker:start": "npm run validate:runtime:worker",
    "lint": "next lint",
    "validate:runtime:web": "tsx scripts/validate-runtime.ts web",
    "validate:runtime:worker": "tsx scripts/validate-runtime.ts worker",
    "whatsapp:backfill:legacy-channel": "tsx --conditions=react-server scripts/backfill-whatsapp-channel.ts",
    "whatsapp:verify:resolution": "tsx --conditions=react-server scripts/verify-whatsapp-channel-resolution.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "bullmq": "^5.46.1",
    "clsx": "^2.1.1",
    "ioredis": "^5.4.1",
    "next": "^15.2.0",
    "openai": "^6.32.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1",
    "tsx": "^4.19.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.22.0",
    "eslint-config-next": "^15.2.0",
    "postcss": "^8.5.3",
    "prisma": "^6.5.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2"
  }
}
