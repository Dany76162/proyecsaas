generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum MembershipRole {
  OWNER
  ADMIN
  AGENT
  ASSISTANT
}

enum LeadStatus {
  NEW
  CONTACTED
  INTERESTED
  VISIT
  CLOSED
}

enum PropertyStatus {
  DRAFT
  AVAILABLE
  RESERVED
  SOLD
  RENTED
}

enum VisitStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELED
}

enum ConversationStatus {
  OPEN
  QUALIFIED
  CLOSED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum NotificationType {
  VISIT_CREATED
}

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  fullName      String
  jobTitle      String?
  isActive      Boolean      @default(true)
  availabilitySlots AvailabilitySlot[]
  memberships   Membership[]
  ownedLeads    Lead[]       @relation("LeadOwner")
  createdVisits Visit[]      @relation("VisitCreatedBy")
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Organization {
  id            String           @id @default(cuid())
  name          String
  slug          String           @unique
  city          String?
  planLabel     String?
  marketFocus   String?
  description   String?
  isActive      Boolean          @default(true)
  memberships   Membership[]
  leads         Lead[]
  properties    Property[]
  conversations Conversation[]
  availability  AvailabilitySlot[]
  notifications Notification[]
  visits        Visit[]
  automations   AutomationRule[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

model Membership {
  id             String         @id @default(cuid())
  role           MembershipRole
  userId         String
  organizationId String
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime       @default(now())

  @@unique([userId, organizationId])
  @@index([organizationId, role])
}

model Lead {
  id             String       @id @default(cuid())
  organizationId String
  ownerId        String?
  propertyId     String?
  fullName       String
  email          String?
  phone          String?
  status         LeadStatus   @default(NEW)
  source         String?
  notes          String?
  interestLabel  String?
  budgetLabel    String?
  lastContactAt  DateTime?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  owner          User?        @relation("LeadOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  property       Property?    @relation("LeadPropertyInterest", fields: [propertyId, organizationId], references: [id, organizationId], onDelete: Restrict)
  conversations  Conversation[]
  visits         Visit[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId, status])
  @@index([organizationId, ownerId])
  @@index([organizationId, propertyId])
  @@unique([id, organizationId])
}

model Property {
  id             String         @id @default(cuid())
  organizationId String
  title          String
  address        String?
  city           String?
  neighborhood   String?
  propertyType   String?
  latitude       Decimal?       @db.Decimal(10, 7)
  longitude      Decimal?       @db.Decimal(10, 7)
  priceCents     Int?
  currency       String?        @default("USD")
  status         PropertyStatus @default(DRAFT)
  publicVisible  Boolean        @default(false)
  bedrooms       Int?
  bathrooms      Int?
  surfaceM2      Int?
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversations  Conversation[] @relation("ConversationPropertyContext")
  interestedLeads Lead[]        @relation("LeadPropertyInterest")
  availability   AvailabilitySlot[]
  visits         Visit[]        @relation("PropertyVisits")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([organizationId, status])
  @@index([organizationId, publicVisible])
  @@unique([id, organizationId])
}

model Conversation {
  id             String       @id @default(cuid())
  organizationId String
  leadId         String?
  propertyId     String?
  channel        String
  status         ConversationStatus @default(OPEN)
  participantName String?
  participantPhone String?
  propertyContextNote String?
  subject        String?
  lastMessageAt  DateTime?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lead           Lead?        @relation(fields: [leadId, organizationId], references: [id, organizationId], onDelete: Restrict)
  property       Property?    @relation("ConversationPropertyContext", fields: [propertyId, organizationId], references: [id, organizationId], onDelete: Restrict)
  messages       Message[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId, channel])
  @@index([organizationId, leadId])
  @@index([organizationId, propertyId])
  @@index([organizationId, status])
  @@unique([id, organizationId])
}

model Message {
  id             String           @id @default(cuid())
  organizationId String
  conversationId String
  direction      MessageDirection
  body           String
  senderName     String?
  senderPhone    String?
  sentAt         DateTime         @default(now())
  conversation   Conversation     @relation(fields: [conversationId, organizationId], references: [id, organizationId], onDelete: Cascade)
  createdAt      DateTime         @default(now())

  @@index([organizationId, conversationId, sentAt])
}

model Visit {
  id             String       @id @default(cuid())
  organizationId String
  propertyId     String
  leadId         String?
  createdById    String
  status         VisitStatus  @default(PENDING)
  scheduledAt    DateTime
  notes          String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property       Property     @relation("PropertyVisits", fields: [propertyId, organizationId], references: [id, organizationId], onDelete: Cascade)
  lead           Lead?        @relation(fields: [leadId, organizationId], references: [id, organizationId], onDelete: Restrict)
  createdBy      User         @relation("VisitCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId, status])
  @@index([organizationId, scheduledAt])
  @@index([organizationId, propertyId])
  @@index([organizationId, leadId])
}

model AvailabilitySlot {
  id             String       @id @default(cuid())
  organizationId String
  propertyId     String?
  userId         String?
  label          String
  weekday        Int
  startMinute    Int
  endMinute      Int
  timezone       String       @default("America/Buenos_Aires")
  isActive       Boolean      @default(true)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property       Property?    @relation(fields: [propertyId, organizationId], references: [id, organizationId], onDelete: Restrict)
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId, weekday, isActive])
  @@index([organizationId, propertyId])
  @@index([organizationId, userId])
}

model Notification {
  id             String           @id @default(cuid())
  organizationId String
  type           NotificationType
  title          String
  body           String
  link           String?
  entityType     String?
  entityId       String?
  readAt         DateTime?
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime         @default(now())

  @@index([organizationId, createdAt])
  @@index([organizationId, type])
}

model AutomationRule {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  trigger        String
  isActive       Boolean      @default(true)
  config         Json?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId, isActive])
}
