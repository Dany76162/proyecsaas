#
# Local development defaults. Replace these with managed service URLs in production.
#
DATABASE_URL="postgresql://proyecsaas_user:1234@localhost:5432/proyecsaas"
DIRECT_URL="postgresql://proyecsaas_user:1234@localhost:5432/proyecsaas"
# Local Prisma migrate helper. In production, point this to the same managed database
# or a dedicated direct/admin connection that can apply migrations safely.
SHADOW_DATABASE_URL="postgresql://proyecsaas_user:1234@localhost:5432/proyecsaas?schema=shadow"
# Required in production for both the web service (webhook enqueue) and worker service.
REDIS_URL="redis://127.0.0.1:6379"
NEXT_PUBLIC_APP_NAME="ProyecSaaS"
# Public app URL used for links rendered by the web app. Set this to the deployed HTTPS URL in production.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
#
# Internal workspace auth.
# Required in production for the web app so signed sessions can be validated and login can verify the shared access key.
#
AUTH_SESSION_SECRET=""
AUTH_SHARED_PASSWORD=""
#
# Runtime WhatsApp delivery / webhook validation.
# These must be injected at runtime in production and should never be committed.
#
# Global app-level webhook secrets still required in production.
WHATSAPP_APP_SECRET=""
WHATSAPP_WEBHOOK_VERIFY_TOKEN=""
#
# AES-256-GCM encryption key for WhatsApp access tokens stored in the database.
# Generate with: openssl rand -hex 32
# Required in production for both the web service (writes) and worker service (reads).
# Without this key new tokens cannot be saved; legacy plaintext tokens keep working read-only.
#
WHATSAPP_TOKEN_ENCRYPTION_KEY=""
#
# Legacy tenant-bound WhatsApp channel fallback.
# These are optional once DB-backed WhatsAppChannel resolution is in use, but if you keep
# legacy fallback enabled they should either all be present or all be absent together.
#
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ORGANIZATION_ID=""
WHATSAPP_ACCESS_TOKEN=""
#
# Optional AI decision layer configuration.
# OPENAI_API_KEY is required only when the LLM decision path should run in the target environment.
#
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4.1-mini"
OPENAI_BASE_URL=""
#
# Mercado Pago integration for platform billing.
# Get credentials at: https://www.mercadopago.com.ar/developers/panel/app
# For sandbox testing, also set MERCADO_PAGO_SANDBOX=true
#
MERCADO_PAGO_ACCESS_TOKEN=""
MERCADO_PAGO_SANDBOX=""
#
# Platform operational settings.
# PLATFORM_WHATSAPP_CONTACT: official platform contact number (digits only, no +54 prefix).
#
PLATFORM_WHATSAPP_CONTACT="1161630205"
#
# Dev-only internal simulation route.
# Do not enable this in production-facing environments unless there is an explicit operational need.
# That route writes real database records and is not a dry run.
#
INTERNAL_AUTOMATION_SIMULATION_TOKEN=""

# UploadThing — image uploads for property gallery
# Get your token at https://uploadthing.com/dashboard → App → API Keys
UPLOADTHING_TOKEN=""

# ─── Email notifications (optional) ────────────────────────────────────────────
# If set, the platform will use Resend to send real emails (password reset, human intervention alerts).
# Without it, emails are logged to the server console (useful for dev/testing).
# Get your API key at https://resend.com/
RESEND_API_KEY=""
EMAIL_FROM="noreply@proyecsaas.com"

# ─── S3-compatible Storage (AWS S3, Cloudflare R2, etc.) ───────────────────────
# Used for persistent image uploads. When not configured, images fall back to
# local filesystem (public/uploads/) which does NOT persist on container restarts.
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""
STORAGE_BUCKET_NAME=""
STORAGE_REGION="auto"
STORAGE_ENDPOINT=""         # Optional: for Cloudflare R2 or custom S3-compatible endpoint
STORAGE_PUBLIC_URL=""       # Optional: CDN URL prefix (e.g., https://pub-xxx.r2.dev)
