#
# Local development defaults. Replace these with managed service URLs in production.
#
DATABASE_URL="postgresql://proyecsaas_user:1234@localhost:5432/proyecsaas"
DIRECT_URL="postgresql://proyecsaas_user:1234@localhost:5432/proyecsaas"
# Local Prisma migrate helper. In production, point this to the same managed database
# or a dedicated direct/admin connection that can apply migrations safely.
SHADOW_DATABASE_URL="postgresql://proyecsaas_user:1234@localhost:5432/proyecsaas?schema=shadow"
# Required in production for both the web service (webhook enqueue) and worker service.
REDIS_URL="redis://127.0.0.1:6379"
NEXT_PUBLIC_APP_NAME="ProyecSaaS"
# Public app URL used for links rendered by the web app. Set this to the deployed HTTPS URL in production.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
#
# Runtime WhatsApp delivery / webhook validation.
# These must be injected at runtime in production and should never be committed.
#
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ORGANIZATION_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_APP_SECRET=""
WHATSAPP_WEBHOOK_VERIFY_TOKEN=""
#
# Optional AI decision layer configuration.
# OPENAI_API_KEY is required only when the LLM decision path should run in the target environment.
#
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4.1-mini"
OPENAI_BASE_URL=""
#
# Dev-only internal simulation route.
# Do not enable this in production-facing environments unless there is an explicit operational need.
# That route writes real database records and is not a dry run.
#
INTERNAL_AUTOMATION_SIMULATION_TOKEN=""
