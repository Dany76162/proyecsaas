DATABASE_URL="postgresql://proyecsaas_user:1234@localhost:5432/proyecsaas"
DIRECT_URL="postgresql://proyecsaas_user:1234@localhost:5432/proyecsaas"
# Use a dedicated shadow schema in the same database if the local user cannot create separate databases.
SHADOW_DATABASE_URL="postgresql://proyecsaas_user:1234@localhost:5432/proyecsaas?schema=shadow"
# Required for BullMQ worker/webhook enqueue outside pure local UI usage.
REDIS_URL="redis://127.0.0.1:6379"
NEXT_PUBLIC_APP_NAME="ProyecSaaS"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Runtime WhatsApp delivery requires all three values below to be set together.
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ORGANIZATION_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_APP_SECRET=""
WHATSAPP_WEBHOOK_VERIFY_TOKEN=""
# Required for the dev-only internal simulation route. That route writes real database records and is not a dry run.
INTERNAL_AUTOMATION_SIMULATION_TOKEN=""
